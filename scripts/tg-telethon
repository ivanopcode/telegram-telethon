#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
VENV_PYTHON="$SKILL_DIR/.venv/bin/python"

if [[ ! -x "$VENV_PYTHON" ]]; then
  printf 'Virtualenv is missing. Run %s/scripts/bootstrap.sh first.\n' "$SKILL_DIR" >&2
  exit 1
fi

exec "$VENV_PYTHON" "$SCRIPT_DIR/telegram_telethon.py" "$@"
